# Copy to .env or export these variables before starting the server.

# First-player proof-data checkout, pointing at gomoku/script.
UPSTREAM_SCRIPT_DIR=./upstream/gomoku/script

# Rapfi build used by both white analysis and general-search black fallback.
RAPFI_DIR=./engines/rapfi
RAPFI_EXE=./engines/rapfi/pbrain-rapfi

# Optional proof-search binary. If the proof tree has no legal continuation,
# the general-search black engine can still handle unsupported positions.
WEB_SEARCH_EXE=./server/web_search

# Optional Gomocup PBrain engine root. Subdirectories are expected to match the
# names documented in README.md.
GOMOCUP_ENGINE_ROOT=./engines/gomocup

WHITE_TURN_TIME_MS=5000
WHITE_RAPFI_DEPTH=64
WHITE_RAPFI_THREADS=4
SEARCH_TURN_TIME_MS=5000
SEARCH_BLACK_DEPTH=64
SEARCH_BLACK_THREADS=4

# Keep the default at 1 to serialize engine state while allowing Tornado to
# keep serving static pages during long searches.
ENGINE_WORKERS=1
